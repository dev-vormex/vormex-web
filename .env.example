# Production: REST stays same-origin through the Next.js /api rewrite, while
# Socket.IO connects directly to Render and authenticates with a short-lived ticket.
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_SOCKET_URL=https://vormex-backend.onrender.com
NEXT_PUBLIC_BASE_URL=https://www.vormex.in
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Keep GOOGLE_CLIENT_SECRET in vormex-backend only. It must never be exposed to the web app.
# Local override example (.env.local):
# NEXT_PUBLIC_API_URL=http://localhost:5000/api
# NEXT_PUBLIC_SOCKET_URL=http://localhost:5000
# NEXT_PUBLIC_BASE_URL=http://localhost:3000
